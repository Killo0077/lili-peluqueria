---
// LiLi Peluquería Canina
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="LiLi Peluquería Canina — Cuidado profesional, amor incondicional."
		/>
		<title>LiLi Peluquería Canina</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,700&display=swap"
			rel="stylesheet"
		/>

		<style>
			/* ── Tokens ── */
			:root {
				--teal: #22abb6;
				--teal-dark: #17929c;
				--teal-light: #e8f5f5;
				--gold: #c8933a;
				--gold-light: #d9a84e;
				--white: #ffffff;
				--yellow: #ecea43;
				--off-white: #f7fafa;
				--text: #1a2e2e;
				--muted: #5a7070;
				--border: #d5e8e8;
				--font: "Nunito", system-ui, sans-serif;
				--green: #0fc03b;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}
			html {
				scroll-behavior: smooth;
			}
			body {
				font-family: var(--font);
				color: var(--text);
				background: var(--white);
				overflow-x: hidden;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			img {
				display: block;
				width: 100%;
			}

			/* ── NAV ── */
			nav {
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				z-index: 50;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1rem 3rem;
			}

			.nav-logo img {
				height: 200px;
				width: auto;
				object-fit: contain;
			}

			/* ── HAMBURGER MENU ── */
			.nav-hamburger {
				display: none;
				flex-direction: column;
				justify-content: center;
				gap: 5px;
				background: none;
				border: 2px solid rgba(255, 255, 255, 0.6);
				border-radius: 0.5rem;
				padding: 0.5rem 0.6rem;
				cursor: pointer;
				z-index: 200;
			}

			.nav-hamburger span {
				display: block;
				width: 22px;
				height: 2px;
				background: var(--white);
				border-radius: 2px;
				transition:
					transform 0.3s,
					opacity 0.3s;
			}

			/* Animate to X when open */
			.nav-hamburger.open span:nth-child(1) {
				transform: translateY(7px) rotate(45deg);
			}
			.nav-hamburger.open span:nth-child(2) {
				opacity: 0;
			}
			.nav-hamburger.open span:nth-child(3) {
				transform: translateY(-7px) rotate(-45deg);
			}

			/* Mobile dropdown panel */
			.mobile-menu {
				display: none;
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 150;
				background: var(--teal-dark);
				padding: 5rem 2rem 2rem;
				flex-direction: column;
				gap: 0;
				box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
				transform: translateY(-100%);
				transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.mobile-menu.open {
				transform: translateY(0);
			}

			.mobile-menu li {
				list-style: none;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
			}

			.mobile-menu li:last-child {
				border-bottom: none;
			}

			.mobile-menu a {
				display: block;
				padding: 1rem 0.5rem;
				font-size: 1.1rem;
				font-weight: 700;
				color: var(--white);
				letter-spacing: 0.02em;
				transition: color 0.2s;
			}

			.mobile-menu a:hover {
				color: var(--gold-light);
			}

			.mobile-menu .mobile-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				margin-top: 1rem;
				padding: 0.85rem 1.5rem;
				background: var(--gold);
				color: var(--white) !important;
				border-radius: 2rem;
				font-size: 0.95rem;
			}

			.mobile-menu .mobile-whatsapp:hover {
				background: var(--gold-light);
			}

			@media (max-width: 768px) {
				.nav-hamburger {
					display: flex;
				}
				.mobile-menu {
					display: flex;
				}
				nav {
					position: fixed;
					background: var(--teal);
				}
				#inicio {
					padding-top: 80px;
				}
			}

			/* Logo placeholder (shown when no image) */
			.nav-logo-placeholder {
				height: 70px;
				width: 140px;
				background: rgba(255, 255, 255, 0.15);
				border-radius: 0.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.3rem;
				font-weight: 800;
				color: var(--white);
				border: 2px dashed rgba(255, 255, 255, 0.4);
				letter-spacing: 0.02em;
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 2rem;
				list-style: none;
			}

			.nav-links a {
				font-size: 2rem;
				font-weight: 900;
				color: var(--yellow);
				opacity: 0.9;
				transition: opacity 0.2s;
				position: relative;
			}

			.nav-links a:hover {
				opacity: 1;
			}

			.nav-links a.active {
				opacity: 1;
				padding-bottom: 3px;
				border-bottom: 2px solid var(--white);
			}

			.nav-whatsapp {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.55rem 1.25rem;
				border: 2px solid var(--white);
				border-radius: 2rem;
				color: var(--white) !important;
				font-weight: 700;
				font-size: 0.9rem;
				opacity: 1 !important;
				transition: background 0.2s !important;
			}

			.nav-whatsapp:hover {
				background: rgba(255, 255, 255, 0.15) !important;
			}

			/* ── HERO ── */
			#inicio {
				position: relative;
				background: var(--teal);
				min-height: 92vh;
				display: flex;
				flex-direction: column;
				overflow: hidden;
				padding-top: 100px;
			}

			/* Watermark dog behind content */
			.hero-watermark {
				position: absolute;
				right: 2%;
				top: 50%;
				transform: translateY(-50%);
				width: 38%;
				opacity: 0.08;
				pointer-events: none;
				z-index: 0;
			}

			.hero-watermark img {
				width: 100%;
				height: auto;
				display: block;
			}

			.hero-content {
				position: relative;
				z-index: 1;
				display: grid;
				grid-template-columns: 1fr 1fr;
				align-items: center;
				flex: 1;
				padding: 2rem 3rem 6rem;
				gap: 2rem;
			}

			.hero-text h1 {
				font-size: clamp(2.2rem, 4.5vw, 3.4rem);
				font-weight: 800;
				color: var(--white);
				line-height: 1.1;
				margin-bottom: 1.5rem;
			}

			.hero-text h1 em {
				font-style: italic;
				font-weight: 700;
				color: var(--yellow);
				display: block;
			}

			.hero-text p {
				font-size: 2rem;
				color: rgba(255, 255, 255, 0.85);
				max-width: 36ch;
				line-height: 1.7;
				margin-bottom: 2rem;
			}

			.hero-btns {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				flex-wrap: wrap;
			}

			.btn-gold {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.8rem 1.6rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 900;
				font-size: 1rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}

			.btn-gold:hover {
				background: var(--gold-light);
				transform: translateY(-2px);
			}

			.btn-ghost-white {
				font-weight: 600;
				font-size: 1rem;
				color: var(--white);
				opacity: 0.9;
				transition: opacity 0.2s;
			}

			.btn-ghost-white:hover {
				opacity: 1;
			}

			/* Hero dog photo (-220 px imagen move to left )*/
			.hero-photo {
				position: relative;
				display: flex;
				justify-content: center;
				align-items: flex-end;

				transform: translateX(-220px);
			}

			.hero-photo-slot {
				width: 90%;
				max-width: 420px;
				aspect-ratio: 3/4;
				background: rgba(255, 255, 255, 0.08);
				border-radius: 1rem;
				border: 2px dashed rgba(255, 255, 255, 0.3);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				color: rgba(255, 255, 255, 0.5);
				font-size: 0.85rem;
				gap: 0.5rem;
			}

			.hero-photo-slot span {
				font-size: 2.5rem;
			}

			/* Trust bar */
			.trust-bar {
				position: relative;
				z-index: 1;

				display: grid;
				grid-template-columns: repeat(4, 1fr);

				gap: 1rem;
				padding: 1rem;

				background: transparent;
			}

			.trust-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;

				padding: 1rem 1.25rem;

				background: rgba(14, 1, 1, 0.18);
				border: 1px solid rgba(243, 6, 6, 0.3);

				border-radius: 16px;

				backdrop-filter: blur(10px);

				transition: all 0.3s ease;
			}

			.trust-item:last-child {
				border-right: none;
			}

			.trust-icon {
				font-size: 1.9rem;
				flex-shrink: 0;
			}

			.trust-label {
				font-size: 1rem;
				font-weight: 800;
				color: white;
				line-height: 1.4;
			}

			/* Wave divider */
			.wave-bottom {
				display: block;
				width: 100%;
				overflow: hidden;
				line-height: 0;
				margin-top: -1px;
			}

			.wave-bottom svg {
				display: block;
				width: 100%;
			}

			/* ── SECTION SHARED ── */
			section {
				padding: 5rem 3rem;
			}

			.section-eyebrow {
				text-align: center;
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--teal);
				margin-bottom: 0.6rem;
			}

			.section-title {
				text-align: center;
				font-size: clamp(1.6rem, 3vw, 2.4rem);
				font-weight: 800;
				color: var(--text);
				margin-bottom: 3rem;
			}

			/* ── SERVICES ── */
			#servicios {
				background: var(--white);
			}

			.services-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.5rem;
				margin-bottom: 2.5rem;
			}

			.service-card {
				border: 1px solid var(--border);
				border-radius: 1rem;
				overflow: hidden;
				background: var(--white);
				transition:
					box-shadow 0.25s,
					transform 0.25s;
			}

			.service-card:hover {
				box-shadow: 0 8px 28px rgba(27, 128, 128, 0.12);
				transform: translateY(-4px);
			}

			.service-top {
				padding: 1.75rem 1.5rem 1.25rem;
				text-align: center;
			}

			.service-svg {
				width: 52px;
				height: 52px;
				margin: 0 auto 1rem;
				color: var(--teal);
			}

			.service-name {
				font-size: 1.05rem;
				font-weight: 800;
				color: var(--text);
				margin-bottom: 0.5rem;
			}

			.service-desc {
				font-size: 0.82rem;
				color: var(--muted);
				line-height: 1.55;
			}

			/* Photo slot inside service card */
			.service-photo {
				width: 100%;
				aspect-ratio: 4/3;
				background: var(--teal-light);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				color: var(--teal);
				font-size: 0.75rem;
				gap: 0.3rem;
				border-top: 1px solid var(--border);
			}

			.service-photo span {
				font-size: 1.8rem;
			}

			/* Replace .service-photo with real img */
			.service-photo img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.services-cta {
				text-align: center;
			}

			.btn-teal {
				display: inline-block;
				padding: 0.8rem 2.25rem;
				background: var(--teal);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}

			.btn-teal:hover {
				background: var(--teal-dark);
				transform: translateY(-2px);
			}

			/* ── GALLERY ── */
			#galeria {
				background: var(--off-white);
			}

			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(6, 1fr);
				gap: 0.75rem;
				margin-bottom: 2rem;
			}

			.gallery-item {
				aspect-ratio: 1;
				border-radius: 0.75rem;
				overflow: hidden;
				background: var(--teal-light);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				color: var(--teal);
				font-size: 0.7rem;
				gap: 0.25rem;
				cursor: pointer;
				transition: transform 0.2s;
			}

			.gallery-item:hover {
				transform: scale(1.03);
			}
			.gallery-item span {
				font-size: 1.5rem;
			}

			/* Replace with: <img src="..." alt="..." style="width:100%;height:100%;object-fit:cover"> */

			.gallery-cta {
				text-align: center;
			}

			.btn-outline-teal {
				display: inline-block;
				padding: 0.7rem 2rem;
				border: 2px solid var(--teal);
				color: var(--teal);
				font-weight: 700;
				font-size: 0.88rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					color 0.2s;
			}

			.btn-outline-teal:hover {
				background: var(--teal);
				color: var(--white);
			}

			/* ── CONTACT / FOOTER ── */
			#contacto {
				background: var(--teal-dark);
				color: var(--white);
				padding: 3.5rem 3rem;
			}

			.footer-grid {
				display: grid;
				grid-template-columns: 1fr 1fr 1fr 1fr;
				gap: 2rem;
				align-items: start;
			}

			.footer-col-title {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 1rem;
				font-weight: 800;
				margin-bottom: 0.75rem;
			}

			.footer-col-title span {
				font-size: 1.15rem;
			}

			.footer-col p,
			.footer-col address {
				font-size: 0.88rem;
				line-height: 1.7;
				opacity: 0.85;
				font-style: normal;
			}

			.footer-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				padding: 0.85rem 1.5rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 700;
				font-size: 0.95rem;
				border-radius: 2rem;
				margin-top: 0.75rem;
				transition: background 0.2s;
			}

			.footer-whatsapp:hover {
				background: var(--gold-light);
			}

			/* Map placeholder */
			.map-placeholder {
				width: 100%;
				aspect-ratio: 4/3;
				background: rgba(255, 255, 255, 0.1);
				border-radius: 0.75rem;
				border: 1px dashed rgba(255, 255, 255, 0.3);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				font-size: 0.78rem;
				opacity: 0.7;
				gap: 0.35rem;
			}

			.map-placeholder span {
				font-size: 1.4rem;
			}

			/* Footer bottom bar */
			.footer-bottom {
				background: var(--teal-dark);
				border-top: 1px solid rgba(255, 255, 255, 0.12);
				padding: 1.25rem 3rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.footer-bottom p {
				font-size: 0.8rem;
				color: rgba(255, 255, 255, 0.6);
			}

			.social-links {
				display: flex;
				gap: 1.25rem;
			}

			.social-links a {
				color: rgba(255, 255, 255, 0.7);
				font-size: 1.3rem;
				transition: color 0.2s;
			}

			.social-links a:hover {
				color: var(--white);
			}

			/* ── RESPONSIVE ── */
			@media (max-width: 1024px) {
				.services-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.gallery-grid {
					grid-template-columns: repeat(3, 1fr);
				}
				.footer-grid {
					grid-template-columns: 1fr 1fr;
				}
			}

			@media (max-width: 768px) {
				nav {
					padding: 1rem 1.25rem;
				}
				.nav-links {
					display: none;
				}
				section {
					padding: 4rem 1.25rem;
				}
				.hero-content {
					grid-template-columns: 1fr;
					padding: 2rem 1.25rem 2rem;
				}
				.hero-photo {
					display: none;
				}
				.trust-bar {
					grid-template-columns: 1fr 1fr;
				}
				.services-grid {
					grid-template-columns: 1fr 1fr;
				}
				.gallery-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.footer-grid {
					grid-template-columns: 1fr;
				}
				.footer-bottom {
					flex-direction: column;
					gap: 0.75rem;
					text-align: center;
				}
			}

			@media (max-width: 480px) {
				.trust-bar {
					grid-template-columns: 1fr;
				}
				.services-grid {
					grid-template-columns: 1fr;
				}
				.gallery-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto;
				}
				* {
					transition: none !important;
				}
			}
		</style>
	</head>

	<body>
		<!-- ══════════════════════════════════════════
         NAV
    ══════════════════════════════════════════ -->
		<nav>
			<!--Logo top left Lili peluqueria -->
			<a href="#inicio" class="nav-logo">
				<img
					src="/lili-peluqueria/images/hero/lili-lettering-yellow.png"
					alt="LiLi Peluquería Canina lettering "
				/>
			</a>

			<ul class="nav-links">
				<li><a href="#inicio" class="active">Inicio</a></li>
				<li><a href="#servicios">Servicios</a></li>
				<li><a href="#galeria">Galería</a></li>
				<li><a href="#sobre">Sobre Lili</a></li>
				<li><a href="#contacto">Contacto</a></li>
				<li>
					<a
						href="https://wa.me/TUNUMERO"
						class="nav-whatsapp"
						target="_blank"
						rel="noopener"
					>
						<!-- WhatsApp icon -->
						<svg
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="currentColor"
							><path
