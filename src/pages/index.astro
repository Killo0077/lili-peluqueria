---
// LiLi Peluquería Canina
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="LiLi Peluquería Canina — Cuidado profesional, amor incondicional."
		/>
		<title>LiLi Peluquería Canina</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,700&display=swap"
			rel="stylesheet"
		/>

		<style>
			/* ── Design Tokens ── */
			:root {
				--teal: #22abb6;
				--teal-dark: #17929c;
				--teal-light: #e8f5f5;
				--gold: #c8933a;
				--gold-light: #d9a84e;
				--white: #ffffff;
				--yellow: #ecea43;
				--off-white: #f7fafa;
				--text: #1a2e2e;
				--muted: #5a7070;
				--border: #d5e8e8;
				--font: "Nunito", system-ui, sans-serif;

				/* Single source of truth for nav height.
				   Every padding-top and scroll-padding uses this. */
				--nav-h: 68px;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html {
				scroll-behavior: smooth;
				/* Offset anchor jumps so content isn't hidden under the fixed nav */
				scroll-padding-top: var(--nav-h);
			}

			body {
				font-family: var(--font);
				color: var(--text);
				background: var(--white);
				overflow-x: hidden;
			}

			a {
				text-decoration: none;
				color: inherit;
			}
			img {
				display: block;
				width: 100%;
			}

			/* ════════════════════════════════
			   NAV
			════════════════════════════════ */
			nav {
				position: fixed; /* fixed on ALL sizes */
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				height: var(--nav-h);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 2.5rem;
				background: var(--teal);
			}

			/* Logo: height tied to nav token, never overflows */
			.nav-logo {
				display: flex;
				align-items: center;
			}
			.nav-logo img {
				height: calc(var(--nav-h) - 20px); /* 48 px on desktop */
				width: auto;
				max-width: 140px;
				object-fit: contain;
			}

			/* Desktop links */
			.nav-links {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				list-style: none;
			}

			.nav-links a {
				font-size: 0.92rem; /* was 2rem — corrected */
				font-weight: 700;
				color: var(--yellow);
				opacity: 0.88;
				transition: opacity 0.2s;
				white-space: nowrap;
			}

			.nav-links a:hover {
				opacity: 1;
			}

			.nav-links a.active {
				opacity: 1;
				border-bottom: 2px solid var(--white);
				padding-bottom: 2px;
			}

			.nav-whatsapp {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.45rem 1rem;
				border: 2px solid rgba(255, 255, 255, 0.8);
				border-radius: 2rem;
				color: var(--white) !important;
				font-size: 0.82rem;
				font-weight: 700;
				opacity: 1 !important;
				white-space: nowrap;
				transition: background 0.2s !important;
			}

			.nav-whatsapp:hover {
				background: rgba(255, 255, 255, 0.15) !important;
			}

			/* ════════════════════════════════
			   HAMBURGER (mobile only)
			════════════════════════════════ */
			.nav-hamburger {
				display: none;
				flex-direction: column;
				justify-content: center;
				gap: 5px;
				background: none;
				border: 2px solid rgba(255, 255, 255, 0.6);
				border-radius: 0.4rem;
				padding: 0.45rem 0.55rem;
				cursor: pointer;
				flex-shrink: 0;
			}

			.nav-hamburger span {
				display: block;
				width: 20px;
				height: 2px;
				background: var(--white);
				border-radius: 2px;
				transition:
					transform 0.3s,
					opacity 0.3s;
			}

			/* ☰ → ✕ animation */
			.nav-hamburger.open span:nth-child(1) {
				transform: translateY(7px) rotate(45deg);
			}
			.nav-hamburger.open span:nth-child(2) {
				opacity: 0;
			}
			.nav-hamburger.open span:nth-child(3) {
				transform: translateY(-7px) rotate(-45deg);
			}

			/* ════════════════════════════════
			   MOBILE SLIDE-DOWN PANEL
			   (slides DOWN from under the nav,
			    not from the side — consistent
			    with the top-fixed nav)
			════════════════════════════════ */
			.mobile-menu {
				display: none;
				position: fixed;
				top: var(--nav-h); /* starts exactly below the nav bar */
				left: 0;
				right: 0;
				z-index: 99;
				background: var(--teal-dark);
				padding: 0.5rem 1.5rem 1.5rem;
				flex-direction: column;
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
				/* hidden state: panel pushed UP behind the nav */
				transform: translateY(-110%);
				transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
				/* max-height + scroll so it never covers the whole screen */
				max-height: calc(100svh - var(--nav-h));
				overflow-y: auto;
			}

			.mobile-menu.open {
				transform: translateY(0);
			}

			.mobile-menu li {
				list-style: none;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
			}
			.mobile-menu li:last-child {
				border-bottom: none;
			}

			.mobile-menu a {
				display: block;
				padding: 0.9rem 0.25rem;
				font-size: 1rem;
				font-weight: 700;
				color: var(--white);
				transition: color 0.2s;
			}
			.mobile-menu a:hover {
				color: var(--gold-light);
			}

			.mobile-menu .mobile-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				margin-top: 0.5rem;
				padding: 0.75rem 1.25rem;
				background: var(--gold);
				color: var(--white) !important;
				border-radius: 2rem;
				font-size: 0.92rem;
				transition: background 0.2s;
			}
			.mobile-menu .mobile-whatsapp:hover {
				background: var(--gold-light);
			}

			/* ════════════════════════════════
			   HERO
			════════════════════════════════ */
			#inicio {
				position: relative;
				background: var(--teal);
				min-height: 100svh; /* svh accounts for mobile browser chrome */
				display: flex;
				flex-direction: column;
				overflow: hidden;
				padding-top: var(
					--nav-h
				); /* matches fixed nav height exactly */
			}

			.hero-watermark {
				position: absolute;
				right: 2%;
				top: 50%;
				transform: translateY(-50%);
				width: 38%;
				opacity: 0.08;
				pointer-events: none;
				z-index: 0;
			}
			.hero-watermark img {
				width: 100%;
				height: auto;
				display: block;
			}

			.hero-content {
				position: relative;
				z-index: 1;
				display: grid;
				grid-template-columns: 1fr 1fr;
				align-items: center;
				flex: 1;
				padding: 2rem 2.5rem 5rem;
				gap: 2rem;
			}

			.hero-text h1 {
				font-size: clamp(1.8rem, 4vw, 3.2rem);
				font-weight: 800;
				color: var(--white);
				line-height: 1.1;
				margin-bottom: 1.25rem;
			}

			.hero-text h1 em {
				font-style: italic;
				font-weight: 700;
				color: var(--yellow);
				display: block;
			}

			.hero-text p {
				font-size: clamp(0.9rem, 1.8vw, 1rem);
				color: rgba(255, 255, 255, 0.85);
				max-width: 38ch;
				line-height: 1.7;
				margin-bottom: 2rem;
			}

			.hero-btns {
				display: flex;
				align-items: center;
				gap: 1.25rem;
				flex-wrap: wrap;
			}

			.btn-gold {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				padding: 0.75rem 1.5rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}
			.btn-gold:hover {
				background: var(--gold-light);
				transform: translateY(-2px);
			}

			.btn-ghost-white {
				font-weight: 600;
				font-size: 0.9rem;
				color: var(--white);
				opacity: 0.88;
				transition: opacity 0.2s;
			}
			.btn-ghost-white:hover {
				opacity: 1;
			}

			/* Hero photo — no more hardcoded translateX */
			.hero-photo {
				display: flex;
				justify-content: center;
				align-items: flex-end;
			}

			.hero-photo img {
				width: 100%;
				max-width: 460px;
				/* guard: image never taller than remaining hero space */
				max-height: calc(100svh - var(--nav-h) - 6rem);
				object-fit: contain;
				border-radius: 1rem;
			}

			/* ════════════════════════════════
			   TRUST BAR
			════════════════════════════════ */
			.trust-bar {
				position: relative;
				z-index: 1;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 0.75rem;
				padding: 0.75rem 1.5rem 1.25rem;
				background: transparent;
			}

			.trust-item {
				display: flex;
				align-items: center;
				gap: 0.65rem;
				padding: 0.85rem 1rem;
				background: rgba(0, 0, 0, 0.18);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 12px;
				backdrop-filter: blur(10px);
				transition: background 0.2s;
			}
			.trust-item:hover {
				background: rgba(0, 0, 0, 0.28);
			}

			.trust-icon {
				font-size: 1.5rem;
				flex-shrink: 0;
			}

			.trust-label {
				font-size: clamp(0.72rem, 1.2vw, 0.88rem);
				font-weight: 700;
				color: var(--white);
				line-height: 1.35;
			}

			/* ════════════════════════════════
			   WAVES
			════════════════════════════════ */
			.wave-bottom {
				display: block;
				width: 100%;
				overflow: hidden;
				line-height: 0;
				margin-top: -1px;
			}
			.wave-bottom svg {
				display: block;
				width: 100%;
			}

			/* ════════════════════════════════
			   SECTION SHARED
			════════════════════════════════ */
			section {
				padding: 5rem 2.5rem;
			}

			.section-eyebrow {
				text-align: center;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--teal);
				margin-bottom: 0.5rem;
			}

			.section-title {
				text-align: center;
				font-size: clamp(1.4rem, 3vw, 2.2rem);
				font-weight: 800;
				color: var(--text);
				margin-bottom: 2.5rem;
			}

			/* ════════════════════════════════
			   SERVICES
			════════════════════════════════ */
			#servicios {
				background: var(--white);
			}

			.services-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.25rem;
				margin-bottom: 2rem;
			}

			.service-card {
				border: 1px solid var(--border);
				border-radius: 1rem;
				overflow: hidden;
				background: var(--white);
				transition:
					box-shadow 0.25s,
					transform 0.25s;
			}
			.service-card:hover {
				box-shadow: 0 8px 28px rgba(27, 128, 128, 0.12);
				transform: translateY(-4px);
			}

			.service-top {
				padding: 1.5rem 1.25rem 1rem;
				text-align: center;
			}
			.service-svg {
				width: 48px;
				height: 48px;
				margin: 0 auto 0.85rem;
				color: var(--teal);
			}
			.service-name {
				font-size: 1rem;
				font-weight: 800;
				color: var(--text);
				margin-bottom: 0.4rem;
			}
			.service-desc {
				font-size: 0.8rem;
				color: var(--muted);
				line-height: 1.55;
			}

			.service-photo {
				width: 100%;
				aspect-ratio: 4/3;
				min-height: 110px;
				overflow: hidden;
				border-top: 1px solid var(--border);
				background: var(--teal-light);
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--teal);
				font-size: 0.75rem;
				gap: 0.3rem;
			}

			.service-photo img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.services-cta {
				text-align: center;
			}

			.btn-teal {
				display: inline-block;
				padding: 0.75rem 2rem;
				background: var(--teal);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}
			.btn-teal:hover {
				background: var(--teal-dark);
				transform: translateY(-2px);
			}

			/* ════════════════════════════════
			   GALLERY
			════════════════════════════════ */
			#galeria {
				background: var(--off-white);
			}

			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(6, 1fr);
				gap: 0.6rem;
				margin-bottom: 1.75rem;
			}

			.gallery-item {
				aspect-ratio: 1;
				min-height: 70px;
				border-radius: 0.65rem;
				overflow: hidden;
				background: var(--teal-light);
				cursor: pointer;
				transition: transform 0.2s;
			}
			.gallery-item:hover {
				transform: scale(1.04);
			}

			.gallery-item img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.gallery-cta {
				text-align: center;
			}

			.btn-outline-teal {
				display: inline-block;
				padding: 0.65rem 1.75rem;
				border: 2px solid var(--teal);
				color: var(--teal);
				font-weight: 700;
				font-size: 0.88rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					color 0.2s;
			}
			.btn-outline-teal:hover {
				background: var(--teal);
				color: var(--white);
			}

			/* ════════════════════════════════
			   FOOTER
			════════════════════════════════ */
			#contacto {
				background: var(--teal-dark);
				color: var(--white);
				padding: 3.5rem 2.5rem;
			}

			.footer-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				align-items: start;
			}

			.footer-col-title {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.95rem;
				font-weight: 800;
				margin-bottom: 0.65rem;
			}

			.footer-col p,
			.footer-col address {
				font-size: 0.85rem;
				line-height: 1.7;
				opacity: 0.85;
				font-style: normal;
			}

			.footer-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.8rem 1.4rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				margin-top: 0.65rem;
				transition: background 0.2s;
			}
			.footer-whatsapp:hover {
				background: var(--gold-light);
			}

			.map-placeholder {
				width: 100%;
				aspect-ratio: 4/3;
				min-height: 100px;
				background: rgba(255, 255, 255, 0.1);
				border-radius: 0.75rem;
				border: 1px dashed rgba(255, 255, 255, 0.3);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				font-size: 0.78rem;
				opacity: 0.7;
				gap: 0.35rem;
				text-align: center;
			}

			.footer-bottom {
				background: var(--teal-dark);
				border-top: 1px solid rgba(255, 255, 255, 0.12);
				padding: 1.1rem 2.5rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.footer-bottom p {
				font-size: 0.78rem;
				color: rgba(255, 255, 255, 0.6);
			}

			.social-links {
				display: flex;
				gap: 1.1rem;
			}
			.social-links a {
				color: rgba(255, 255, 255, 0.7);
				transition: color 0.2s;
			}
			.social-links a:hover {
				color: var(--white);
			}

			/* ════════════════════════════════
			   RESPONSIVE BREAKPOINTS
			════════════════════════════════ */

			/* Tablet landscape ≤ 1060px: tighten nav, keep desktop layout */
			@media (max-width: 1060px) {
				nav {
					padding: 0 1.5rem;
				}
				.nav-links {
					gap: 1rem;
				}
				.nav-links a {
					font-size: 0.82rem;
				}
				.nav-whatsapp {
					padding: 0.4rem 0.8rem;
					font-size: 0.78rem;
				}
			}

			/* Tablet portrait ≤ 900px: 2-col grids, 2×2 trust bar */
			@media (max-width: 900px) {
				.services-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.gallery-grid {
					grid-template-columns: repeat(3, 1fr);
				}
				.footer-grid {
					grid-template-columns: 1fr 1fr;
				}
				.trust-bar {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			/* Mobile ≤ 768px: hamburger menu, single-column hero */
			@media (max-width: 768px) {
				/* Smaller nav height on mobile saves vertical space */
				:root {
					--nav-h: 58px;
				}

				nav {
					padding: 0 1rem;
				}
				.nav-links {
					display: none;
				} /* hide desktop links */
				.nav-hamburger {
					display: flex;
				} /* show hamburger */
				.mobile-menu {
					display: flex;
				} /* enable panel */

				section {
					padding: 3rem 1.1rem;
				}

				/* for smallers screens */
				#inicio {
					min-height: auto;
					padding-bottom: 1rem;
				}

				.hero-text h1 {
					font-size: clamp(1.5rem, 6vm, 2rem);
					margin-bottom: 0.85rem;
				}

				.hero-text p {
					font-size: 0.9rem;
					margin-bottom: 1.25rem;
				}
				/* end */

				.hero-content {
					grid-template-columns: 1fr;
					padding: 1.5rem 1.1rem 1.5rem;
					gap: 1rem;
				}

				/* Show photo on mobile but smaller */
				.hero-photo {
					justify-content: center;
				}
				.hero-photo img {
					max-width: 260px;
					max-height: 240px;
					border-radius: 0.75rem;
				}

				.services-grid {
					grid-template-columns: 1fr 1fr;
				}
				.gallery-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.footer-grid {
					grid-template-columns: 1fr;
				}

				#contacto {
					padding: 2.5rem 1.1rem;
				}

				.footer-bottom {
					flex-direction: column;
					gap: 0.65rem;
					text-align: center;
					padding: 1rem 1.1rem;
				}
			}

			/* Small phones ≤ 480px: single column for services and trust bar */
			@media (max-width: 480px) {
				.trust-bar {
					grid-template-columns: 1fr;
				}

				/* Hide photo on very small screens to give text room */
				.hero-photo {
					display: none;
				}

				.services-grid {
					grid-template-columns: 1fr;
				}
				.gallery-grid {
					grid-template-columns: repeat(2, 1fr);
				}

				.hero-btns {
					gap: 0.75rem;
				}
				.btn-gold,
				.btn-ghost-white {
					font-size: 0.82rem;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto;
				}
				* {
					transition: none !important;
				}
			}
		</style>
	</head>

	<body>
		<!-- ══ NAV ══════════════════════════════════ -->
		<nav>
			<a href="#inicio" class="nav-logo">
				<img
					src="/lili-peluqueria/images/hero/lili-lettering-yellow.png"
					alt="LiLi Peluquería Canina"
				/>
			</a>

			<ul class="nav-links">
				<li><a href="#inicio" class="active">Inicio</a></li>
