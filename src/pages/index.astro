---
// LiLi Peluquería Canina
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/images/hero/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="LiLi Peluquería Canina — Baño, corte y cuidado profesional para que tu perro se vea y se sienta genial."
		/>
		<title>LiLi Peluquería Canina</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;0,900;1,800;1,900&display=swap"
			rel="stylesheet"
		/>

		<style>
			:root {
				--teal: #22abb6;
				--teal-dark: #17929c;
				--teal-light: #e8f5f5;
				--teal-mid: #d0eef0;
				--gold: #c8933a;
				--gold-light: #d9a84e;
				--white: #ffffff;
				--yellow: #ecea43;
				--cream: #f9f6f0;
				--off-white: #f7fafa;
				--text: #1a2e2e;
				--muted: #5a7070;
				--border: #d5e8e8;
				--font: "Nunito", system-ui, sans-serif;
				--nav-h: 72px;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}
			html {
				scroll-behavior: smooth;
				scroll-padding-top: var(--nav-h);
			}
			body {
				font-family: var(--font);
				color: var(--text);
				background: var(--white);
				overflow-x: hidden;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			img {
				display: block;
				width: 100%;
			}

			/* ── NAV ── */
			nav {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				height: var(--nav-h);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 2rem;
				background: var(--white);
				border-bottom: 1px solid rgba(0, 0, 0, 0.06);
				box-shadow: 0 1px 12px rgba(0, 0, 0, 0.06);
			}

			/* Logo image in nav */
			.nav-logo {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.nav-logo img {
				height: calc(var(--nav-h) - 24px);
				width: auto;
				max-width: 120px;
				object-fit: contain;
			}
			.nav-logo-sub {
				font-size: 0.7rem;
				font-weight: 600;
				color: var(--muted);
				line-height: 1.2;
				display: block;
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				list-style: none;
			}

			.nav-links a {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text);
				opacity: 0.75;
				transition:
					opacity 0.2s,
					color 0.2s;
				white-space: nowrap;
			}
			.nav-links a:hover {
				opacity: 1;
				color: var(--teal);
			}
			.nav-links a.active {
				opacity: 1;
				color: var(--teal);
				border-bottom: 2px solid var(--teal);
				padding-bottom: 2px;
			}

			.nav-whatsapp {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.5rem 1.1rem;
				background: var(--teal);
				color: var(--white) !important;
				font-size: 0.82rem;
				font-weight: 700;
				border-radius: 2rem;
				opacity: 1 !important;
				white-space: nowrap;
				transition: background 0.2s !important;
			}
			.nav-whatsapp:hover {
				background: var(--teal-dark) !important;
			}

			/* ── HAMBURGER ── */
			.nav-hamburger {
				display: none;
				flex-direction: column;
				justify-content: center;
				gap: 5px;
				background: none;
				border: 2px solid var(--border);
				border-radius: 0.4rem;
				padding: 0.45rem 0.55rem;
				cursor: pointer;
				flex-shrink: 0;
			}
			.nav-hamburger span {
				display: block;
				width: 20px;
				height: 2px;
				background: var(--text);
				border-radius: 2px;
				transition:
					transform 0.3s,
					opacity 0.3s;
			}
			.nav-hamburger.open span:nth-child(1) {
				transform: translateY(7px) rotate(45deg);
			}
			.nav-hamburger.open span:nth-child(2) {
				opacity: 0;
			}
			.nav-hamburger.open span:nth-child(3) {
				transform: translateY(-7px) rotate(-45deg);
			}

			/* ── MOBILE MENU ── */
			.mobile-menu {
				display: none;
				position: fixed;
				top: var(--nav-h);
				left: 0;
				right: 0;
				z-index: 99;
				background: var(--white);
				border-top: 1px solid var(--border);
				padding: 0.5rem 1.5rem 1.5rem;
				flex-direction: column;
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
				transform: translateY(-110%);
				transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
				max-height: calc(100svh - var(--nav-h));
				overflow-y: auto;
			}
			.mobile-menu.open {
				transform: translateY(0);
			}
			.mobile-menu li {
				list-style: none;
				border-bottom: 1px solid var(--border);
			}
			.mobile-menu li:last-child {
				border-bottom: none;
			}
			.mobile-menu a {
				display: block;
				padding: 0.9rem 0.25rem;
				font-size: 1rem;
				font-weight: 700;
				color: var(--text);
				transition: color 0.2s;
			}
			.mobile-menu a:hover {
				color: var(--teal);
			}
			.mobile-menu .mobile-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				margin-top: 0.75rem;
				padding: 0.75rem 1.25rem;
				background: var(--teal);
				color: var(--white) !important;
				border-radius: 2rem;
				font-size: 0.92rem;
				font-weight: 700;
				transition: background 0.2s;
			}
			.mobile-menu .mobile-whatsapp:hover {
				background: var(--teal-dark);
			}

			/* ── HERO ── */
			#inicio {
				position: relative;
				background: var(--cream);
				min-height: calc(100svh - var(--nav-h));
				padding-top: var(--nav-h);
				overflow: hidden;
				display: flex;
				align-items: center;
			}

			/* Soft cream overlay so text stays readable */
			#inicio::before {
				content: "";
				position: absolute;
				inset: 0;
				z-index: 1;
				pointer-events: none;
				background: linear-gradient(
					90deg,
					rgba(249, 246, 240, 1) 0%,
					rgba(249, 246, 240, 0.96) 34%,
					rgba(249, 246, 240, 0.72) 56%,
					rgba(249, 246, 240, 0.2) 82%,
					rgba(249, 246, 240, 0) 100%
				);
			}

			.hero-bg-dog {
				position: absolute;
				right: 0;
				bottom: 0;
				width: 64%;
				height: calc(100% - var(--nav-h));
				object-fit: cover;
				object-position: center right;
				z-index: 0;
				pointer-events: none;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				width: 100%;
				max-width: 560px;
				margin-left: 7%;
				padding: 4rem 0;
			}

			.hero-text {
				max-width: 480px;
			}

			.hero-eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background: var(--teal-mid);
				color: var(--teal-dark);
				font-size: 0.8rem;
				font-weight: 800;
				padding: 0.45rem 1rem;
				border-radius: 999px;
				margin-bottom: 1.25rem;
			}

			.hero-text h1 {
				font-size: clamp(2.7rem, 5vw, 4.7rem);
				font-weight: 900;
				line-height: 0.95;
				color: var(--text);
				margin-bottom: 1rem;
			}

			.hero-text h1 .brand-name {
				display: block;
				font-style: italic;
				color: var(--gold);
				font-size: clamp(3rem, 5.5vw, 5rem);
				line-height: 1;
			}

			.hero-text p {
				font-size: 1.05rem;
				color: var(--text);
				line-height: 1.6;
				max-width: 36ch;
				margin-bottom: 1.5rem;
			}

			.hero-btns {
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
				margin-bottom: 1.25rem;
			}

			.btn-gold {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				padding: 0.9rem 1.75rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 800;
				font-size: 0.95rem;
				border-radius: 999px;
				box-shadow: 0 8px 22px rgba(200, 147, 58, 0.3);
				transition:
					background 0.2s,
					transform 0.2s;
			}

			.btn-gold:hover {
				background: var(--gold-light);
				transform: translateY(-2px);
			}

			.btn-gold-sub {
				display: block;
				font-size: 0.68rem;
				font-weight: 700;
				opacity: 0.9;
				margin-top: 0.1rem;
			}

			.btn-ghost-teal {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.45rem;
				padding: 0.85rem 1.5rem;
				border: 2px solid rgba(34, 171, 182, 0.45);
				border-radius: 999px;
				font-weight: 800;
				color: var(--teal-dark);
				background: rgba(255, 255, 255, 0.55);
			}

			.hero-star-line {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--muted);
			}

			.hero-photo {
				display: none;
			}

			/*Google review */
			.hero-rating {
	display: flex;
	align-items: center;
	gap: 0.9rem;
	width: fit-content;

	background: #fff;
	padding: 0.85rem 1.1rem;
	border-radius: 18px;
	box-shadow: 0 12px 35px rgba(0, 0, 0, 0.1);

	margin-top: 1rem;
}

.hero-stars {
	color: var(--gold);
	font-size: 1.05rem;
	letter-spacing: 0.12rem;
	line-height: 1;
}

.hero-rating-text {
	display: flex;
	flex-direction: column;
}

.hero-rating-text strong {
	color: var(--text);
	font-size: 0.95rem;
}

.hero-rating-text span {
	color: #7b8794;
	font-size: 0.8rem;
}

@media (max-width: 768px) {
	.hero-rating {
		margin-top: 1rem;
		padding: 0.75rem 1rem;
	}
}
			@media (max-width: 768px) {
				#inicio {
					min-height: calc(100svh - var(--nav-h));
					padding-top: var(--nav-h);
					align-items: center;
				}

				#inicio::before {
					background: linear-gradient(
						90deg,
						rgba(249, 246, 240, 1) 0%,
						rgba(249, 246, 240, 0.97) 48%,
						rgba(249, 246, 240, 0.78) 70%,
						rgba(249, 246, 240, 0.35) 100%
					);
				}

				.hero-bg-dog {
					position: absolute;
					right: -88px;
					bottom: 36px;
					width: 108%;
					height: 62%;
					object-fit: contain;
					object-position: right bottom;
					opacity: 1;
				}

				.hero-content {
					max-width: 100%;
					margin-left: 0;
					padding: 2rem 1.45rem;
				}

				.hero-text {
					max-width: 285px;
				}

				.hero-eyebrow {
					font-size: 0.72rem;
					padding: 0.4rem 0.8rem;
				}

				.hero-text h1 {
					font-size: 2.55rem;
				}

				.hero-text h1 .brand-name {
					font-size: 3rem;
				}

				.hero-text p {
					font-size: 1rem;
					max-width: 26ch;
				}

				.hero-btns {
					align-items: flex-start;
					gap: 0.8rem;
				}

				.btn-gold {
					padding: 0.85rem 1.35rem;
				}

				.btn-ghost-teal {
					padding: 0.75rem 1.25rem;
				}
			}

			/* ── TRUST SECTION ── */
			.trust-section {
				background: var(--teal);
				padding: 2.5rem 3rem;
			}

			.trust-section-title {
				text-align: center;
				font-size: 1rem;
				font-weight: 800;
				color: var(--white);
				margin-bottom: 1.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
			}

			.trust-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
			}

			.trust-card {
				background: rgba(255, 255, 255, 0.12);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 1rem;
				padding: 1.25rem 1rem;
				text-align: center;
				backdrop-filter: blur(8px);
				transition: background 0.2s;
			}
			.trust-card:hover {
				background: rgba(255, 255, 255, 0.2);
			}

			.trust-card-icon {
				font-size: 1.75rem;
				margin-bottom: 0.5rem;
			}

			.trust-card-title {
				font-size: 0.88rem;
				font-weight: 800;
				color: var(--white);
				margin-bottom: 0.35rem;
				line-height: 1.3;
			}

			.trust-card-desc {
				font-size: 0.75rem;
				color: rgba(255, 255, 255, 0.8);
				line-height: 1.5;
			}

			/* ── WAVE ── */
			.wave-divider {
				display: block;
				width: 100%;
				overflow: hidden;
				line-height: 0;
				margin-top: -1px;
			}
			.wave-divider svg {
				display: block;
				width: 100%;
			}

			/* ── SECTION SHARED ── */
			section {
				padding: 5rem 3rem;
			}

			.section-eyebrow {
				text-align: center;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.4rem;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--teal);
				margin-bottom: 0.5rem;
			}

			.section-title {
				text-align: center;
				font-size: clamp(1.4rem, 3vw, 2.2rem);
				font-weight: 900;
				color: var(--text);
				margin-bottom: 2.5rem;
			}

			/* ── SERVICES ── */
			#servicios {
				background: var(--white);
			}

			.services-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.25rem;
				margin-bottom: 2rem;
			}

			.service-card {
				border: 1px solid var(--border);
				border-radius: 1rem;
				overflow: hidden;
				background: var(--white);
				transition:
					box-shadow 0.25s,
					transform 0.25s;
			}
			.service-card:hover {
				box-shadow: 0 8px 28px rgba(27, 128, 128, 0.12);
				transform: translateY(-4px);
			}

			.service-top {
				padding: 1.5rem 1.25rem 1rem;
				text-align: center;
			}
			.service-svg {
				width: 44px;
				height: 44px;
				margin: 0 auto 0.75rem;
				color: var(--teal);
			}
			.service-name {
				font-size: 0.95rem;
				font-weight: 800;
				color: var(--text);
				margin-bottom: 0.35rem;
			}
			.service-desc {
				font-size: 0.78rem;
				color: var(--muted);
				line-height: 1.55;
			}

			.service-photo {
				width: 100%;
				aspect-ratio: 4/3;
				min-height: 110px;
				overflow: hidden;
				border-top: 1px solid var(--border);
				background: var(--teal-light);
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--teal);
				font-size: 0.75rem;
			}
			.service-photo img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.services-cta {
				text-align: center;
			}

			.btn-teal {
				display: inline-block;
				padding: 0.75rem 2rem;
				background: var(--teal);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}
			.btn-teal:hover {
				background: var(--teal-dark);
				transform: translateY(-2px);
			}

			/* ── GALLERY ── */
			#galeria {
				background: var(--off-white);
			}

			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(6, 1fr);
				gap: 0.6rem;
				margin-bottom: 1.75rem;
			}

			.gallery-item {
				aspect-ratio: 1;
				min-height: 70px;
				border-radius: 0.65rem;
				overflow: hidden;
				background: var(--teal-light);
				cursor: pointer;
				transition: transform 0.2s;
			}
			.gallery-item:hover {
				transform: scale(1.04);
			}
			.gallery-item img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.gallery-cta {
				text-align: center;
			}

			.gallery-cta {
				display: flex;
				justify-content: center;
				margin-top: 2rem;
			}

			.instagram-logo {
				width: 180px;
				transition: 0.25s ease;
			}

			.instagram-logo:hover {
				transform: scale(1.05);
				opacity: 0.9;
			}

			.btn-outline-teal {
				display: inline-block;
				padding: 0.65rem 1.75rem;
				border: 2px solid var(--teal);
				color: var(--teal);
				font-weight: 700;
				font-size: 0.88rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					color 0.2s;
			}
			.btn-outline-teal:hover {
				background: var(--teal);
				color: var(--white);
			}

			/* Reviews */
			.reviews-section {
				background: var(--white);
				padding: 5rem 1.5rem;
				text-align: center;
			}

			.section-subtitle {
				color: var(--muted);
				margin: 0.75rem auto 3rem;
				max-width: 520px;
			}

			.reviews-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.5rem;
				max-width: 1100px;
				margin: 0 auto;
			}

			.review-card {
				background: #dfcfb5; /*var(--cream) */
				border-radius: 1.25rem;
				padding: 1.6rem;
				text-align: left;
				box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
			}

			.stars {
				color: var(--gold);
				letter-spacing: 0.15rem;
				margin-bottom: 1rem;
			}

			.review-card p {
				color: var(--muted);
				line-height: 1.6;
			}

			.review-card hr {
				border: none;
				border-top: 1px solid rgba(0, 0, 0, 0.08);
				margin: 1.2rem 0;
			}

			.review-card strong {
				display: block;
				color: var(--text);
			}

			.review-card span {
				font-size: 0.85rem;
				color: var(--muted);
			}

			@media (max-width: 768px) {
				.reviews-grid {
					grid-template-columns: 1fr;
				}
			}

			/* ── FOOTER ── */
			#contacto {
				background: var(--teal-dark);
				color: var(--white);
				padding: 3.5rem 3rem;
			}

			.footer-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				align-items: start;
			}

			.footer-col-title {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.95rem;
				font-weight: 800;
				margin-bottom: 0.65rem;
			}

			.footer-col p,
			.footer-col address {
				font-size: 0.85rem;
				line-height: 1.7;
				opacity: 0.85;
				font-style: normal;
			}

			.footer-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.8rem 1.4rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				margin-top: 0.65rem;
				transition: background 0.2s;
			}
			.footer-whatsapp:hover {
