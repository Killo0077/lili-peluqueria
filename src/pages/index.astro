---
// LiLi Peluquería Canina
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="LiLi Peluquería Canina — Baño, corte y cuidado profesional para que tu perro se vea y se sienta genial."
		/>
		<title>LiLi Peluquería Canina</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;0,900;1,800;1,900&display=swap"
			rel="stylesheet"
		/>

		<style>
			:root {
				--teal: #22abb6;
				--teal-dark: #17929c;
				--teal-light: #e8f5f5;
				--teal-mid: #d0eef0;
				--gold: #c8933a;
				--gold-light: #d9a84e;
				--white: #ffffff;
				--cream: #f9f6f0;
				--off-white: #f7fafa;
				--text: #1a2e2e;
				--muted: #5a7070;
				--border: #d5e8e8;
				--font: "Nunito", system-ui, sans-serif;
				--nav-h: 72px;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}
			html {
				scroll-behavior: smooth;
				scroll-padding-top: var(--nav-h);
			}
			body {
				font-family: var(--font);
				color: var(--text);
				background: var(--white);
				overflow-x: hidden;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			img {
				display: block;
				width: 100%;
			}

			/* ════════════════════════════════
			   NAV
			════════════════════════════════ */
			nav {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				height: var(--nav-h);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 1.5rem;
				background: var(--white);
				border-bottom: 1px solid rgba(0, 0, 0, 0.06);
				box-shadow: 0 1px 12px rgba(0, 0, 0, 0.06);
			}

			.nav-logo {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				line-height: 1;
				text-decoration: none;
			}
			.nav-logo img {
				height: calc(var(--nav-h) - 28px);
				width: auto;
				max-width: 110px;
				object-fit: contain;
			}
			.nav-logo-sub {
				font-size: 0.62rem;
				font-weight: 600;
				color: var(--muted);
				letter-spacing: 0.03em;
				margin-top: 1px;
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 1.25rem;
				list-style: none;
			}
			.nav-links a {
				font-size: 1rem;
				font-weight: 700;
				color: var(--text);
				opacity: 0.7;
				transition:
					opacity 0.2s,
					color 0.2s;
				white-space: nowrap;
			}
			.nav-links a:hover {
				opacity: 1;
				color: var(--teal);
			}
			.nav-links a.active {
				opacity: 1;
				color: var(--teal);
				border-bottom: 2px solid var(--teal);
				padding-bottom: 2px;
			}

			.nav-whatsapp {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.55rem 1.25rem;
				background: var(--teal);
				color: var(--white) !important;
				font-size: 0.95rem;
				font-weight: 700;
				border-radius: 2rem;
				opacity: 1 !important;
				white-space: nowrap;
				transition: background 0.2s !important;
			}
			.nav-whatsapp:hover {
				background: var(--teal-dark) !important;
			}

			/* ════════════════════════════════
			   HAMBURGER
			════════════════════════════════ */
			.nav-hamburger {
				display: none;
				flex-direction: column;
				justify-content: center;
				gap: 5px;
				background: none;
				border: 2px solid var(--border);
				border-radius: 0.4rem;
				padding: 0.45rem 0.55rem;
				cursor: pointer;
				flex-shrink: 0;
			}
			.nav-hamburger span {
				display: block;
				width: 20px;
				height: 2px;
				background: var(--text);
				border-radius: 2px;
				transition:
					transform 0.3s,
					opacity 0.3s;
			}
			.nav-hamburger.open span:nth-child(1) {
				transform: translateY(7px) rotate(45deg);
			}
			.nav-hamburger.open span:nth-child(2) {
				opacity: 0;
			}
			.nav-hamburger.open span:nth-child(3) {
				transform: translateY(-7px) rotate(-45deg);
			}

			/* ════════════════════════════════
			   MOBILE MENU
			════════════════════════════════ */
			.mobile-menu {
				display: none;
				position: fixed;
				top: var(--nav-h);
				left: 0;
				right: 0;
				z-index: 99;
				background: var(--white);
				border-top: 1px solid var(--border);
				padding: 0.5rem 1.5rem 1.5rem;
				flex-direction: column;
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
				transform: translateY(-110%);
				transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
				max-height: calc(100svh - var(--nav-h));
				overflow-y: auto;
			}
			.mobile-menu.open {
				transform: translateY(0);
			}
			.mobile-menu li {
				list-style: none;
				border-bottom: 1px solid var(--border);
			}
			.mobile-menu li:last-child {
				border-bottom: none;
			}
			.mobile-menu a {
				display: block;
				padding: 0.9rem 0.25rem;
				font-size: 1rem;
				font-weight: 700;
				color: var(--text);
				transition: color 0.2s;
			}
			.mobile-menu a:hover {
				color: var(--teal);
			}
			.mobile-menu .mobile-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				margin-top: 0.75rem;
				padding: 0.75rem 1.25rem;
				background: var(--teal);
				color: var(--white) !important;
				border-radius: 2rem;
				font-size: 0.92rem;
				font-weight: 700;
				transition: background 0.2s;
			}
			.mobile-menu .mobile-whatsapp:hover {
				background: var(--teal-dark);
			}

			/* ════════════════════════════════
			   HERO
			   Split layout: left=text, right=photo
			   Photo bleeds to top/right/bottom edges
			════════════════════════════════ */
			#inicio {
				position: relative;
				background: var(--cream);
				min-height: 100svh;
				display: grid;
				grid-template-columns: 1fr 1fr;
				overflow: hidden;
				padding-top: var(--nav-h);
			}

			/* LEFT: text column */
			.hero-text {
				display: flex;
				flex-direction: column;
				justify-content: center;
				padding: 3rem 2.5rem 3rem 3rem;
				z-index: 1;
			}

			.hero-eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background: var(--teal-mid);
				color: var(--teal-dark);
				font-size: 0.95rem;
				font-weight: 700;
				padding: 0.3rem 0.8rem;
				border-radius: 2rem;
				margin-bottom: 1rem;
				width: fit-content;
			}

			.hero-text h1 {
				font-size: clamp(2.4rem, 4.5vw, 4rem);
				font-weight: 900;
				color: var(--text);
				line-height: 1.05;
				margin-bottom: 0.2rem;
			}

			.hero-text h1 .brand-name {
				font-style: italic;
				color: var(--gold);
				display: block;
				font-size: clamp(2.8rem, 5.5vw, 4.8rem);
				line-height: 1.05;
				margin-bottom: 0.75rem;
			}

			.hero-text > p {
				font-size: clamp(1rem, 1.6vw, 1.15rem);
				color: var(--muted);
				max-width: 36ch;
				line-height: 1.6;
				margin-bottom: 1.25rem;
			}

			/* Mini icons row */
			.hero-icons {
				display: flex;
				gap: 1rem;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}
			.hero-icon-item {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.25rem;
				font-size: 0.62rem;
				font-weight: 700;
				color: var(--muted);
				text-align: center;
				min-width: 44px;
			}
			.hero-icon-item svg {
				width: 30%;
				height: 30%;
				color: var(--teal);
			}

			/* Buttons */
			.hero-btns {
				display: flex;
				align-items: center;
				gap: 0.85rem;
				flex-wrap: wrap;
				margin-bottom: 1rem;
			}

			.btn-gold {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.9rem 1.6rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 800;
				font-size: 1rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
				box-shadow: 0 4px 14px rgba(200, 147, 58, 0.3);
			}
			.btn-gold:hover {
				background: var(--gold-light);
				transform: translateY(-2px);
			}

			/* Small tag below WhatsApp button */
			.btn-gold-wrap {
				display: flex;
				flex-direction: column;
				gap: 0.2rem;
			}
			.btn-gold-tag {
				font-size: 0.6rem;
				color: var(--muted);
				padding-left: 0.25rem;
			}

			.btn-ghost-teal {
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
				font-weight: 700;
				font-size: 1rem;
				color: var(--text);
				opacity: 0.7;
				transition: opacity 0.2s;
				border: 1.5px solid rgba(0, 0, 0, 0.15);
				padding: 0.85rem 1.25rem;
				border-radius: 2rem;
			}
			.btn-ghost-teal:hover {
				opacity: 1;
				border-color: var(--teal);
				color: var(--teal);
			}

			.hero-star-line {
				display: flex;
				align-items: center;
				gap: 0.35rem;
				font-size: 0.88rem;
				font-weight: 600;
				color: var(--muted);
			}
			.hero-star-line svg {
				color: var(--gold);
				width: 14px;
				height: 14px;
			}

			/* RIGHT: photo column — bleeds to all edges */
			.hero-photo {
				position: relative;
				overflow: hidden;
				/* pull photo flush to nav top, right edge, and bottom */
				margin-top: calc(-1 * var(--nav-h));
				padding-top: var(--nav-h);
			}
			.hero-photo img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: right top;
			}

			/* ════════════════════════════════
			   TRUST SECTION
			════════════════════════════════ */
			.trust-section {
				background: var(--teal);
				padding: 2.5rem 2.5rem;
			}
			.trust-section-title {
				text-align: center;
				font-size: 1rem;
				font-weight: 800;
				color: var(--white);
				margin-bottom: 1.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
			}
			.trust-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
			}
			.trust-card {
				background: rgba(255, 255, 255, 0.12);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 1rem;
				padding: 1.25rem 1rem;
				text-align: center;
				backdrop-filter: blur(8px);
				transition: background 0.2s;
			}
			.trust-card:hover {
				background: rgba(255, 255, 255, 0.2);
			}
			.trust-card-icon {
				font-size: 1.6rem;
				margin-bottom: 0.5rem;
			}
			.trust-card-title {
				font-size: 0.95rem;
				font-weight: 800;
				color: var(--white);
				margin-bottom: 0.3rem;
				line-height: 1.3;
			}
			.trust-card-desc {
				font-size: 0.82rem;
				color: rgba(255, 255, 255, 0.8);
				line-height: 1.5;
			}

			/* ════════════════════════════════
			   WAVES
			════════════════════════════════ */
			.wave-divider {
				display: block;
				width: 100%;
				overflow: hidden;
				line-height: 0;
				margin-top: -1px;
			}
			.wave-divider svg {
				display: block;
				width: 100%;
			}

			/* ════════════════════════════════
			   SECTIONS SHARED
			════════════════════════════════ */
			section {
				padding: 5rem 2.5rem;
			}

			.section-eyebrow {
				text-align: center;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.4rem;
				font-size: 0.82rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--teal);
				margin-bottom: 0.5rem;
			}
			.section-title {
				text-align: center;
				font-size: clamp(1.7rem, 3.5vw, 2.6rem);
				font-weight: 900;
				color: var(--text);
				margin-bottom: 2.5rem;
			}

			/* ════════════════════════════════
			   SERVICES
			════════════════════════════════ */
			#servicios {
				background: var(--white);
			}

			.services-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1.25rem;
				margin-bottom: 2rem;
			}
			.service-card {
				border: 1px solid var(--border);
				border-radius: 1rem;
				overflow: hidden;
				background: var(--white);
				transition:
					box-shadow 0.25s,
					transform 0.25s;
			}
			.service-card:hover {
				box-shadow: 0 8px 28px rgba(27, 128, 128, 0.12);
				transform: translateY(-4px);
			}
			.service-top {
				padding: 1.5rem 1.25rem 1rem;
				text-align: center;
			}
			.service-svg {
				width: 44px;
				height: 44px;
				margin: 0 auto 0.75rem;
				color: var(--teal);
			}
			.service-name {
				font-size: 1.05rem;
				font-weight: 800;
				color: var(--text);
				margin-bottom: 0.35rem;
			}
			.service-desc {
				font-size: 0.88rem;
				color: var(--muted);
				line-height: 1.55;
			}
			.service-photo {
				width: 100%;
				aspect-ratio: 4/3;
				min-height: 110px;
				overflow: hidden;
				border-top: 1px solid var(--border);
				background: var(--teal-light);
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.service-photo img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.services-cta {
				text-align: center;
			}
			.btn-teal {
				display: inline-block;
				padding: 0.75rem 2rem;
				background: var(--teal);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					transform 0.2s;
			}
			.btn-teal:hover {
				background: var(--teal-dark);
				transform: translateY(-2px);
			}

			/* ════════════════════════════════
			   GALLERY
			════════════════════════════════ */
			#galeria {
				background: var(--off-white);
			}
			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(6, 1fr);
				gap: 0.6rem;
				margin-bottom: 1.75rem;
			}
			.gallery-item {
				aspect-ratio: 1;
				min-height: 70px;
				border-radius: 0.65rem;
				overflow: hidden;
				background: var(--teal-light);
				cursor: pointer;
				transition: transform 0.2s;
			}
			.gallery-item:hover {
				transform: scale(1.04);
			}
			.gallery-item img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.gallery-cta {
				text-align: center;
			}
			.btn-outline-teal {
				display: inline-block;
				padding: 0.65rem 1.75rem;
				border: 2px solid var(--teal);
				color: var(--teal);
				font-weight: 700;
				font-size: 0.88rem;
				border-radius: 2rem;
				transition:
					background 0.2s,
					color 0.2s;
			}
			.btn-outline-teal:hover {
				background: var(--teal);
				color: var(--white);
			}

			/* ════════════════════════════════
			   FOOTER
			════════════════════════════════ */
			#contacto {
				background: var(--teal-dark);
				color: var(--white);
				padding: 3.5rem 2.5rem;
			}
			.footer-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 2rem;
				align-items: start;
			}
			.footer-col-title {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.95rem;
				font-weight: 800;
				margin-bottom: 0.65rem;
			}
			.footer-col p,
			.footer-col address {
				font-size: 0.95rem;
				line-height: 1.7;
				opacity: 0.85;
				font-style: normal;
			}
			.footer-whatsapp {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.8rem 1.4rem;
				background: var(--gold);
				color: var(--white);
				font-weight: 700;
				font-size: 0.9rem;
				border-radius: 2rem;
				margin-top: 0.65rem;
				transition: background 0.2s;
			}
			.footer-whatsapp:hover {
				background: var(--gold-light);
			}
			.map-placeholder {
				width: 100%;
				aspect-ratio: 4/3;
				min-height: 100px;
				background: rgba(255, 255, 255, 0.1);
				border-radius: 0.75rem;
				border: 1px dashed rgba(255, 255, 255, 0.3);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				font-size: 0.78rem;
				opacity: 0.7;
				gap: 0.35rem;
				text-align: center;
			}
			.footer-bottom {
				background: var(--teal-dark);
				border-top: 1px solid rgba(255, 255, 255, 0.12);
				padding: 1.1rem 2.5rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.footer-bottom p {
				font-size: 0.88rem;
				color: rgba(255, 255, 255, 0.6);
			}
			.social-links {
				display: flex;
				gap: 1.1rem;
			}
			.social-links a {
				color: rgba(255, 255, 255, 0.7);
				transition: color 0.2s;
			}
			.social-links a:hover {
				color: var(--white);
			}

			/* ════════════════════════════════
			   RESPONSIVE
			════════════════════════════════ */
			@media (max-width: 1060px) {
				nav {
					padding: 0 1.25rem;
				}
				.nav-links {
					gap: 1rem;
				}
				.nav-links a {
					font-size: 0.78rem;
				}
				.hero-text {
					padding: 2rem 1.5rem 2rem 2rem;
				}
			}

			@media (max-width: 900px) {
				.services-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.gallery-grid {
					grid-template-columns: repeat(3, 1fr);
				}
				.footer-grid {
					grid-template-columns: 1fr 1fr;
				}
				.trust-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			/* ── Mobile ≤ 768px ── */
			@media (max-width: 768px) {
				:root {
					--nav-h: 60px;
				}

				nav {
					padding: 0 1rem;
				}
				.nav-links {
					display: none;
				}
				.nav-hamburger {
					display: flex;
				}
				.mobile-menu {
					display: flex;
				}

				/* Stack hero vertically: photo on top, text below */
				/* #inicio {
					grid-template-columns: 1fr;
					grid-template-rows: 52vw auto;
					min-height: auto;
				} */
				.hero-photo {
					display: none;
				}
				/* Photo row — fixed height, full width */
				.hero-photo {
					grid-row: 1;
					margin-top: 0;
					padding-top: 0;
					height: 52vw;
					min-height: 200px;
					max-height: 320px;
				}

